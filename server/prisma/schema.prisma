generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  openid      String   @unique
  unionid     String?
  nickname    String?
  avatar      String?
  phone       String?
  coins       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
  unlocked    UnlockedChapter[]
  records     ReadingRecord[]
  comments    Comment[]
  bookmarks   Bookmark[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  cover       String?
  summary     String?
  category    String?
  tags        String?
  price       Int      @default(0)
  status      String   @default("ongoing")
  wordCount   Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())

  chapters    Chapter[]
  shelves     BookShelf[]
}

model Chapter {
  id        Int    @id @default(autoincrement())
  bookId    Int
  title     String
  content   String
  order     Int
  price     Int    @default(0)
  isFree    Boolean @default(false)
  createdAt DateTime @default(now())

  book      Book   @relation(fields: [bookId], references: [id])
  unlocked  UnlockedChapter[]
  comments  Comment[]
  bookmarks Bookmark[]
  summaries ChapterSummary[]
  reads     ChapterRead[]
}

model UnlockedChapter {
  id         Int      @id @default(autoincrement())
  userId     Int
  chapterId  Int
  unlockType String   @default("paid")
  unlockedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  chapter    Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([userId, chapterId])
}

model AdToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AdDailyLimit {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String
  count     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Order {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  coinAmount Int
  status    String   @default("pending")
  payMethod String?
  createdAt DateTime @default(now())
  paidAt    DateTime?

  user      User     @relation(fields: [userId], references: [id])
}

model ReadingRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  bookId     Int
  chapterId  Int?
  progress   Float    @default(0)
  lastReadAt DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  @@unique([userId, bookId])
}

model Comment {
  id             Int      @id @default(autoincrement())
  userId         Int
  bookId         Int
  chapterId      Int
  content        String
  paragraphIndex Int?     // null = 章评，number = 段评
  parentId       Int?     // 回复某条评论
  likes          Int      @default(0)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  chapter        Chapter  @relation(fields: [chapterId], references: [id])

  @@index([chapterId, createdAt])
  @@index([bookId, createdAt])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  chapterId Int
  paragraphIndex Int?
  note      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  chapter   Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([userId, chapterId, paragraphIndex])
}

model ChapterSummary {
  id        Int      @id @default(autoincrement())
  chapterId Int
  content   String   // AI 总结内容
  source    String   @default("ai") // ai / manual
  createdAt DateTime @default(now())

  chapter   Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([chapterId])
}

model BookShelf {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model ReaderConfig {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  fontSize    Int      @default(18)
  lineHeight  Int      @default(160)
  theme       String   @default("light")
  brightness  Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChapterRead {
  id        Int      @id @default(autoincrement())
  userId    Int
  chapterId Int
  readAt    DateTime @default(now())
  chapter   Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([userId, chapterId])
}
