   301|    '--text-title': '#1a1a1a',
   302|    '--panel-bg': 'rgba(255,255,255,0.95)',
   303|    '--border-color': '#e0e0d8',
   304|    '--accent': '#B8451A',
   305|    '--text-secondary': '#666666',
   306|    '--text-muted': '#999999',
   307|  },
   308|  sepia: {
   309|    '--page-bg': '#F4ECD8',
   310|    '--text-primary': '#5B4B3A',
   311|    '--text-title': '#3D2B1F',
   312|    '--panel-bg': 'rgba(244,236,216,0.95)',
   313|    '--border-color': '#D9CBA0',
   314|    '--accent': '#8B6914',
   315|    '--text-secondary': '#7A6B5A',
   316|    '--text-muted': '#A09080',
   317|  },
   318|  green: {
   319|    '--page-bg': '#C7EDCC',
   320|    '--text-primary': '#2F4F2F',
   321|    '--text-title': '#1A3A1A',
   322|    '--panel-bg': 'rgba(199,237,204,0.95)',
   323|    '--border-color': '#A8D8B0',
   324|    '--accent': '#2E8B57',
   325|    '--text-secondary': '#4A7A4A',
   326|    '--text-muted': '#6A9A6A',
   327|  },
   328|};
   329|
   330|const book = ref<Partial<Book>>({});
   331|const chapters = ref<Chapter[]>([]);
   332|const chapterId = ref(1);
   333|const fontSize = ref(32);
   334|const theme = ref<ThemeKey>('dark');
   335|const lineHeight = ref(1.8);
   336|const paragraphGap = ref(24);
   337|const brightness = ref(100);
   338|const fontFamily = ref('system');
   339|const pageTurn = ref('slide');
   340|
   341|const fontList = [
   342|  { key: 'system', label: '系统默认' },
   343|  { key: 'serif', label: '思源宋体' },
   344|  { key: 'sans', label: '思源黑体' },
   345|  { key: 'mono', label: '等宽字体' },
   346|];
   347|
   348|const pageTurnList = [
   349|  { key: 'slide', label: '滑动' },
   350|  { key: 'cover', label: '覆盖' },
   351|  { key: 'sim', label: '仿真' },
   352|  { key: 'none', label: '无' },
   353|];
   354|
   355|const themeStyle = computed(() => ({
   356|  ...themeVars[theme.value],
   357|  ...(brightness.value !== 100 ? { filter: `brightness(${brightness.value}%)` } : {}),
   358|}));
   359|
   360|const showUI = ref(false);
   361|const showSettings = ref(false);
   362|const showCatalogPanel = ref(false);
   363|const showAdModal = ref(false);
   364|const adProgress = ref(0);
   365|const adUnlocking = ref(false);
   366|const isLoading = ref(false);
   367|const contentOpacity = ref(1);
   368|const scrollTop = ref(0);
   369|const pageAnimClass = ref('');
   370|
   371|/* ========== 连续流阅读核心状态 ========== */
   372|interface ChapterBlock {
   373|  id: number;
   374|  title: string;
   375|  content: string;
   376|  locked: boolean;
   377|  paragraphs: string[];
   378|}
   379|
   380|const blocks = ref<ChapterBlock[]>([]);
   381|const currentVisibleChapterId = ref(1);
   382|const isLoadingMore = ref(false);
   383|const isLoadingPrev = ref(false);
   384|const scrollIntoView = ref('');
   385|const inShelf = ref(false);
   386|const isPlaying = ref(false);
   387|const readChapterIds = ref<Set<number>>(new Set());
   388|let progressTimer: any = null;
   389|let configSaveTimer: any = null;
   390|const allLoaded = ref(false);
   391|const pendingUnlockChapterId = ref<number | null>(null);
   392|let adTimer: any = null;
   393|const preloadCache = ref<Map<number, any>>(new Map());
   394|let isRestoringScroll = false;
   395|
   396|/* ========== 计算属性 ========== */
   397|const currentBlockTitle = computed(() => {
   398|  const block = blocks.value.find(b => b.id === currentVisibleChapterId.value);
   399|  return block?.title || '';
   400|});
   401|
   402|const currentChapterIndex = computed(() =>
   403|  chapters.value.findIndex(c => c.id === currentVisibleChapterId.value)
   404|);
   405|
   406|const chapterProgress = computed(() => {
   407|  if (chapters.value.length === 0) return 0;
   408|  return Math.round(((currentChapterIndex.value + 1) / chapters.value.length) * 100);
   409|});
   410|
   411|/* ========== 生命周期 ========== */
   412|onLoad(async (opts: any) => {
   413|  const bid = parseInt(opts?.bookId || '1');
   414|  const cid = parseInt(opts?.chapterId || '1');
   415|  chapterId.value = cid;
   416|  currentVisibleChapterId.value = cid;
   417|
   418|  try {
   419|    const [b, chs, shelfRes, config] = await Promise.all([
   420|      fetchBook(bid),
   421|      fetchChapters(bid),
   422|      checkShelf(bid).catch(() => ({ inShelf: false })),
   423|      fetchReaderConfig().catch(() => null),
   424|    ]);
   425|    if (b) book.value = b;
   426|    if (chs) chapters.value = chs;
   427|    inShelf.value = shelfRes.inShelf;
   428|
   429|    // 加载用户配置
   430|    if (config) {
   431|      if (config.fontSize) fontSize.value = config.fontSize;
   432|      if (config.lineHeight) lineHeight.value = config.lineHeight / 100;
   433|      if (config.theme) theme.value = config.theme as ThemeKey;
   434|      if (config.brightness) brightness.value = config.brightness;
   435|    }
   436|
   437|    // 如果 URL 明确指定了 chapterId（从目录/详情页主动跳转），优先使用它，不恢复进度
   438|    let targetId = cid;
   439|    if (!opts?.chapterId) {
   440|      const restoredId = await restoreProgress(bid);
   441|      if (restoredId) targetId = restoredId;
   442|    }
   443|
   444|    chapterId.value = targetId;
   445|    currentVisibleChapterId.value = targetId;
   446|    await loadChapter(targetId);
   447|
   448|    // 启动进度上报定时器
   449|    progressTimer = setInterval(() => {
   450|      if (book.value.id && currentVisibleChapterId.value) {
   451|        const container = getScrollContainer();
   452|        const progress = container
   453|          ? Math.min(1, Math.max(0, container.scrollTop / (container.scrollHeight - container.clientHeight)))
   454|          : 0;
   455|        saveProgress(book.value.id, currentVisibleChapterId.value, progress).catch(() => {});
   456|      }
   457|    }, 30000); // 30s 上报一次
   458|  } catch (e) {
   459|    console.error('fetch reader failed', e);
   460|  }
   461|});
   462|
   463|onUnmounted(() => {
   464|  if (progressTimer) clearInterval(progressTimer);
   465|  if (configSaveTimer) clearTimeout(configSaveTimer);
   466|});
   467|
   468|// 监听配置变化，自动保存
   469|watch([fontSize, lineHeight, theme, brightness], () => {
   470|  debounceSaveConfig();
   471|}, { deep: true });
   472|
   473|// H5 下 scroll-view 内部 Vue @click 不生效，用原生监听器补充
   474|// 注意：监听器绑定在 .reader-content 而非 .reader-inner，避免 contentKey 变化导致 inner 重建后事件丢失
   475|onMounted(() => {
   476|  // #ifdef H5
   477|  setTimeout(() => {
   478|    const content = document.querySelector('.reader-content');
   479|    if (content) {
   480|      content.addEventListener('click', (e) => {
   481|        const target = e.target as HTMLElement;
   482|        // 只处理点击在 reader-inner 内部的事件，且排除交互元素
   483|        if (target.closest('.reader-inner') && !target.closest('.unlock-ad-btn')) {
   484|          onPageClick(e as any);
   485|        }
   486|      });
   487|    }
   488|  }, 500);
   489|  // #endif
   490|});
   491|
   492|/* ========== 章节加载 ========== */
   493|function makeBlock(data: any): ChapterBlock {
   494|  return {
   495|    id: data.id,
   496|    title: data.title || '加载中...',
   497|    content: data.content || '',
   498|    locked: data.locked,
   499|    paragraphs: data.content ? data.content.split('\n\n') : [],
   500|  };
   501|}
   502|
   503|async function loadChapter(id: number, direction: 'prev' | 'next' | 'init' = 'init') {
   504|  isLoading.value = true;
   505|  allLoaded.value = true; // 先阻止触底加载，避免空内容触发底部事件
   506|  blocks.value = [];      // 清空内容，v-if 会链式销毁 reader-inner，彻底清除 scroll 状态
   507|  contentOpacity.value = 0;
   508|
   509|  try {
   510|    // 等待 reader-inner 销毁，scroll-view 内部滚动状态彻底清除
   511|    await nextTick();
   512|
   513|    // 确保滚动归零
   514|    scrollTop.value = 0;
   515|    // #ifdef H5
   516|    const container = getScrollContainer();
   517|    if (container) container.scrollTop = 0;
   518|    // #endif
   519|
   520|    const data = await fetchChapter(id);
   521|    blocks.value = [makeBlock(data)];
   522|    chapterId.value = id;
   523|    currentVisibleChapterId.value = id;
   524|
   525|    // 等待新的 reader-inner 创建渲染
   526|    await nextTick();
   527|
   528|    // 再次确保滚动归零（新内容渲染后 scroll-view 可能自动滚动）
   529|    scrollTop.value = 0;
   530|    // #ifdef H5
   531|    if (container) container.scrollTop = 0;
   532|    // #endif
   533|
   534|    allLoaded.value = false; // 恢复触底加载
   535|    contentOpacity.value = 1;
   536|    applyPageAnim(direction);
   537|    saveReadingProgress();
   538|    markCurrentChapterRead();
   539|
   540|    // 初始化时加载下一章到连续流（仅限免费章节），让用户一进来就能连续滚动
   541|    const idx = chapters.value.findIndex(c => c.id === id);
   542|    if (idx >= 0 && idx < chapters.value.length - 1) {
   543|      const nextCh = chapters.value[idx + 1];
   544|      if (nextCh.isFree) {
   545|        try {
   546|          const nextData = await fetchChapter(nextCh.id);
   547|          blocks.value.push(makeBlock(nextData));
   548|        } catch (e) { /* ignore */ }
   549|      } else {
   550|        preloadChapter(nextCh.id);
   551|      }
   552|    }
   553|  } catch (e) {
   554|    console.error('load chapter failed', e);
   555|  } finally {
   556|    isLoading.value = false;
   557|  }
   558|}
   559|
   560|async function preloadChapter(id: number) {
   561|  if (preloadCache.value.has(id)) return;
   562|  try {
   563|    const data = await fetchChapter(id);
   564|    preloadCache.value.set(id, data);
   565|  } catch (e) { /* ignore */ }
   566|}
   567|
   568|function getCachedChapter(id: number) {
   569|  return preloadCache.value.get(id);
   570|}
   571|
   572|async function jumpToChapter(id: number, direction: 'prev' | 'next' | 'init' = 'init') {
   573|  // 如果目标章节已在连续流中，直接滚动过去
   574|  const existingIdx = blocks.value.findIndex(b => b.id === id);
   575|  if (existingIdx >= 0) {
   576|    scrollIntoView.value = '';
   577|    await nextTick();
   578|    scrollIntoView.value = 'ch-' + id;
   579|    currentVisibleChapterId.value = id;
   580|    chapterId.value = id;
   581|    saveReadingProgress();
   582|    markCurrentChapterRead();
   583|    return;
   584|  }
   585|  // 不在当前窗口（跳得太远），回退到清空重载
   586|  await loadChapter(id, direction);
   587|}
   588|
   589|function applyPageAnim(direction: 'prev' | 'next' | 'init') {
   590|  if (pageTurn.value === 'none' || direction === 'init') {
   591|    pageAnimClass.value = '';
   592|    return;
   593|  }
   594|  const animMap: Record<string, Record<string, string>> = {
   595|    slide: { next: 'anim-slide-left', prev: 'anim-slide-right' },
   596|    cover: { next: 'anim-cover-in', prev: 'anim-cover-out' },
   597|    sim: { next: 'anim-sim-right', prev: 'anim-sim-left' },
   598|  };
   599|  const targetClass = animMap[pageTurn.value]?.[direction] || '';
   600|  // 先清空再赋值，确保 Vue 检测到变化从而触发 CSS 动画
   601|  pageAnimClass.value = '';
   602|  requestAnimationFrame(() => {
   603|    pageAnimClass.value = targetClass;
   604|  });
   605|  // 800ms 后清除动画类，避免后续滚动触发重复动画
   606|  setTimeout(() => { pageAnimClass.value = ''; }, 800);
   607|}
   608|
   609|/* ========== 连续流：触顶追加上一章 ========== */
   610|async function onScrollToUpper() {
   611|  if (isLoadingPrev.value || isLoadingMore.value) return;
   612|
   613|  const firstBlock = blocks.value[0];
   614|  if (!firstBlock) return;
   615|
   616|  const idx = chapters.value.findIndex(c => c.id === firstBlock.id);
   617|  if (idx <= 0) return; // 已经是第一章
   618|
   619|  isLoadingPrev.value = true;
   620|  isRestoringScroll = true;
   621|  const prevCh = chapters.value[idx - 1];
   622|
   623|  try {
   624|    const cached = getCachedChapter(prevCh.id);
   625|    const data = cached || await fetchChapter(prevCh.id);
   626|
   627|    // 记录旧第一个 block 的 id，以便插入后定位
   628|    const oldFirstId = firstBlock.id;
   629|
   630|    blocks.value.unshift(makeBlock(data));
   631|
   632|    // 等待 DOM 更新后，直接通过原生 scrollTo 恢复位置（绕过 scroll-view 组件内部覆盖逻辑）
   633|    await nextTick();
   634|    // #ifdef H5
   635|    const container = getScrollContainer();
   636|    if (container) {
   637|      const oldEl = container.querySelector('.chapter-block[data-id="' + oldFirstId + '"]') as HTMLElement;
   638|      if (oldEl) {
   639|        const start = performance.now();
   640|        const forceLoop = () => {
   641|          const elRect = oldEl.getBoundingClientRect();
   642|          const containerRect = container.getBoundingClientRect();
   643|          const target = container.scrollTop + elRect.top - containerRect.top;
   644|          if ('scrollTo' in container) {
   645|            container.scrollTo({ top: target, behavior: 'instant' });
   646|          } else {
   647|            container.scrollTop = target;
   648|          }
   649|          scrollTop.value = target;
   650|          if (performance.now() - start < 800) {
   651|            requestAnimationFrame(forceLoop);
   652|          } else {
   653|            isRestoringScroll = false;
   654|          }
   655|        };
   656|        forceLoop();
   657|      } else {
   658|        isRestoringScroll = false;
   659|      }
   660|    } else {
   661|      isRestoringScroll = false;
   662|    }
   663|    // #endif
   664|    // #ifndef H5
   665|    isRestoringScroll = false;
   666|    // #endif
   667|
   668|    // 预加载上上一章
   669|    if (idx - 2 >= 0) {
   670|      preloadChapter(chapters.value[idx - 2].id);
   671|    }
   672|  } catch (e) {
   673|    console.error('prepend chapter failed', e);
   674|    isRestoringScroll = false;
   675|  } finally {
   676|    isLoadingPrev.value = false;
   677|    trimBlocks();
   678|  }
   679|}
   680|
   681|/* ========== 连续流：触底追加下一章 ========== */
   682|async function onScrollToLower() {
   683|  if (isLoadingMore.value || isLoadingPrev.value || allLoaded.value) return;
   684|
   685|  const lastBlock = blocks.value[blocks.value.length - 1];
   686|  if (!lastBlock || lastBlock.locked) return;
   687|
   688|  const idx = chapters.value.findIndex(c => c.id === lastBlock.id);
   689|  if (idx < 0 || idx >= chapters.value.length - 1) {
   690|    allLoaded.value = true;
   691|    return;
   692|  }
   693|
   694|  isLoadingMore.value = true;
   695|  const nextCh = chapters.value[idx + 1];
   696|
   697|  try {
   698|    const cached = getCachedChapter(nextCh.id);
   699|    const data = cached || await fetchChapter(nextCh.id);
   700|    blocks.value.push(makeBlock(data));
   701|
   702|    // 预加载下下一章
   703|    if (idx + 2 < chapters.value.length) {
   704|      preloadChapter(chapters.value[idx + 2].id);
   705|    }
   706|  } catch (e) {
   707|    console.error('append chapter failed', e);
   708|  } finally {
   709|    isLoadingMore.value = false;
   710|    trimBlocks();
   711|  }
   712|}
   713|
   714|/* ========== 滚动追踪当前章节 ========== */
   715|let scrollTimer: any = null;
   716|
   717|function onScroll(e: any) {
   718|  if (isSmoothScrolling || isRestoringScroll) return; // 平滑滚动/位置恢复期间屏蔽，避免与 :scroll-top 绑定冲突
   719|  scrollTop.value = e.detail.scrollTop;
   720|  if (scrollTimer) clearTimeout(scrollTimer);
   721|  scrollTimer = setTimeout(() => {
   722|    updateVisibleChapter();
   723|  }, 150);
   724|}
   725|
   726|function updateVisibleChapter() {
   727|  if (blocks.value.length === 0) return;
   728|
   729|  // #ifdef H5
   730|  try {
   731|    const container = getScrollContainer();
   732|    if (!container) return;
   733|    const st = container.scrollTop;
   734|    const blockEls = document.querySelectorAll('.chapter-block');
   735|
   736|    for (let i = blockEls.length - 1; i >= 0; i--) {
   737|      const el = blockEls[i] as HTMLElement;
   738|      if (el.offsetTop <= st + 200) {
   739|        const id = parseInt(el.getAttribute('data-id') || '1');
   740|        if (currentVisibleChapterId.value !== id) {
   741|          currentVisibleChapterId.value = id;
   742|          chapterId.value = id;
   743|          saveReadingProgress();
   744|        }
   745|        break;
   746|      }
   747|    }
   748|  } catch (e) {}
   749|  // #endif
   750|}
   751|
   752|/* ========== 广告解锁 ========== */
   753|async function startAdUnlock(blockChapterId?: number) {
   754|  pendingUnlockChapterId.value = blockChapterId || chapterId.value;
   755|  showAdModal.value = true;
   756|  adProgress.value = 0;
   757|  const total = 3000;
   758|  const step = 100;
   759|  let elapsed = 0;
   760|  if (adTimer) clearInterval(adTimer);
   761|  adTimer = setInterval(() => {
   762|    elapsed += step;
   763|    adProgress.value = Math.min(100, Math.floor((elapsed / total) * 100));
   764|    if (elapsed >= total) {
   765|      clearInterval(adTimer);
   766|      adTimer = null;
   767|      finishAd();
   768|    }
   769|  }, step);
   770|}
   771|
   772|async function finishAd() {
   773|  adUnlocking.value = true;
   774|  if (adTimer) { clearInterval(adTimer); adTimer = null; }
   775|  try {
   776|    const tokenRes = await adComplete();
   777|    console.log('[finishAd] adComplete result:', JSON.stringify(tokenRes));
   778|    if (!tokenRes.token) throw new Error('no token');
   779|    const targetId = pendingUnlockChapterId.value || chapterId.value;
   780|    const res = await adUnlock(targetId, tokenRes.token);
   781|    console.log('[finishAd] adUnlock result:', JSON.stringify(res));
   782|    if (res.success) {
   783|      showAdModal.value = false;
   784|      uni.showToast({ title: '解锁成功', icon: 'success' });
   785|
   786|      // 同步更新 chapters 数组锁定状态（用 splice 确保响应式）
   787|      const chIdx = chapters.value.findIndex(c => c.id === targetId);
   788|      if (chIdx >= 0) {
   789|        chapters.value.splice(chIdx, 1, { ...chapters.value[chIdx], isFree: true });
   790|      }
   791|
   792|      const idx = blocks.value.findIndex(b => b.id === targetId);
   793|      console.log('[finishAd] targetId:', targetId, 'block idx:', idx);
   794|      if (idx >= 0) {
   795|        const data = await fetchChapter(targetId);
   796|        console.log('[finishAd] fetchChapter result:', {id: data.id, locked: data.locked, hasContent: !!data.content});
   797|        blocks.value.splice(idx, 1, makeBlock(data));
   798|      } else {
   799|        await loadChapter(targetId);
   800|      }
   801|    } else {
   802|      uni.showToast({ title: res.error || '解锁失败', icon: 'none' });
   803|    }
   804|  } catch (e: any) {
   805|    console.error('[finishAd] error:', e);
   806|    uni.showToast({ title: e.message || '解锁失败', icon: 'none' });
   807|  } finally {
   808|    adUnlocking.value = false;
   809|    pendingUnlockChapterId.value = null;
   810|  }
   811|}
   812|
   813|function closeAd() {
   814|  showAdModal.value = false;
   815|  adProgress.value = 0;
   816|  if (adTimer) { clearInterval(adTimer); adTimer = null; }
   817|}
   818|
   819|/* ========== UI 交互 ========== */
   820|const toggleUI = () => {
   821|  if (showSettings.value) {
   822|    showSettings.value = false;
   823|    return;
   824|  }
   825|  showUI.value = !showUI.value;
   826|};
   827|
   828|/* 左右点击翻页 */
   829|function onPageClick(e: any) {
   830|  // 如果弹窗或目录打开，不处理
   831|  if (showAdModal.value || showCatalogPanel.value) return;
   832|
   833|  // uni-app H5 点击事件可能有多种形式
   834|  const x = e.detail?.x ?? e.clientX ?? e.pageX ?? 0;
   835|  const { windowWidth } = uni.getSystemInfoSync();
   836|
   837|  if (x < windowWidth * 0.3) {
   838|    // 左侧 30% → 上一屏
   839|    scrollByPage(-1);
   840|  } else if (x > windowWidth * 0.7) {
   841|    // 右侧 30% → 下一屏
   842|    scrollByPage(1);
   843|  } else {
   844|    // 中间 40% → 切换菜单
   845|    toggleUI();
   846|  }
   847|}
   848|
   849|function getScrollContainer(): HTMLElement | null {
   850|  // #ifdef H5
   851|  const reader = document.querySelector('.reader-content');
   852|  if (!reader) return null;
   853|  return reader.querySelector('div[style*="overflow: hidden auto"]') as HTMLElement || null;
   854|  // #endif
   855|  // #ifndef H5
   856|  return null;
   857|  // #endif
   858|}
   859|
   860|let isSmoothScrolling = false;
   861|
   862|function smoothScrollTo(container: HTMLElement, target: number, duration = 280) {
   863|  if (isSmoothScrolling) return;
   864|  isSmoothScrolling = true;
   865|  const start = container.scrollTop;
   866|  const distance = target - start;
   867|  const startTime = performance.now();
   868|
   869|  function step(currentTime: number) {
   870|    const elapsed = currentTime - startTime;
   871|    const progress = Math.min(elapsed / duration, 1);
   872|    // ease-out cubic
   873|    const ease = 1 - Math.pow(1 - progress, 3);
   874|    container.scrollTop = start + distance * ease;
   875|    if (progress < 1) {
   876|      requestAnimationFrame(step);
   877|    } else {
   878|      isSmoothScrolling = false;
   879|      scrollTop.value = container.scrollTop;
   880|    }
   881|  }
   882|  requestAnimationFrame(step);
   883|}
   884|
   885|function scrollByPage(direction: number) {
   886|  // #ifdef H5
   887|  try {
   888|    const container = getScrollContainer();
   889|    if (!container) return;
   890|
   891|    if (direction > 0) {
   892|      // 向下翻页
   893|      const maxScroll = container.scrollHeight - container.clientHeight;
   894|      if (container.scrollTop >= maxScroll - 20) {
   895|        // 已经在底部，切换下一章（带动画）
   896|        nextChapter();
   897|      } else {
   898|        smoothScrollTo(
   899|          container,
   900|          container.scrollTop + container.clientHeight * 0.98
   901|        );
   902|      }
   903|    } else {
   904|      // 向上翻页
   905|      if (container.scrollTop <= 20) {
   906|        // 已经在顶部，切换上一章（带动画）
   907|        prevChapter();
   908|      } else {
   909|        smoothScrollTo(
   910|          container,
   911|          Math.max(0, container.scrollTop - container.clientHeight * 0.98)
   912|        );
   913|      }
   914|    }
   915|  } catch (e) {}
   916|  // #endif
   917|}
   918|
   919|const prevChapter = () => {
   920|  const idx = chapters.value.findIndex(c => c.id === currentVisibleChapterId.value);
   921|  if (idx > 0) {
   922|    const prev = chapters.value[idx - 1];
   923|    jumpToChapter(prev.id, 'prev');
   924|    if (idx - 2 >= 0) preloadChapter(chapters.value[idx - 2].id);
   925|  }
   926|};
   927|
   928|const nextChapter = () => {
   929|  const idx = chapters.value.findIndex(c => c.id === currentVisibleChapterId.value);
   930|  if (idx >= 0 && idx < chapters.value.length - 1) {
   931|    const next = chapters.value[idx + 1];
   932|    jumpToChapter(next.id, 'next');
   933|    if (idx + 2 < chapters.value.length) preloadChapter(chapters.value[idx + 2].id);
   934|  }
   935|};
   936|
   937|const showCatalog = () => {
   938|  showCatalogPanel.value = true;
   939|};
   940|
   941|const selectChapter = (ch: Chapter) => {
   942|  showCatalogPanel.value = false;
   943|  showUI.value = false;
   944|  showSettings.value = false;
   945|  const currentIdx = chapters.value.findIndex(c => c.id === currentVisibleChapterId.value);
   946|  const targetIdx = chapters.value.findIndex(c => c.id === ch.id);
   947|  const dir = targetIdx > currentIdx ? 'next' : targetIdx < currentIdx ? 'prev' : 'init';
   948|  jumpToChapter(ch.id, dir);
   949|};
   950|
   951|const onProgressChange = (e: any) => {
   952|  const pct = e.detail.value / 100;
   953|  const idx = Math.round(pct * (chapters.value.length - 1));
   954|  const ch = chapters.value[idx];
   955|  if (ch) {
   956|    jumpToChapter(ch.id);
   957|  }
   958|};
   959|
   960|/* ========== 进度保存/恢复 ========== */
   961|async function restoreProgress(bookId: number) {
   962|  const token = uni.getStorageSync('token');
   963|  if (!token) return null;
   964|  try {
   965|    const res: any = await uni.request({
   966|      url: '/api/books/' + bookId + '/progress',
   967|      header: { Authorization: 'Bearer ' + token },
   968|    });
   969|    const data = res.data;
   970|    if (data && data.chapterId) {
   971|      return data.chapterId;
   972|    }
   973|  } catch (e) {}
   974|  return null;
   975|}
   976|
   977|async function saveReadingProgress() {
   978|  const token = uni.getStorageSync('token');
   979|  if (!token || !book.value.id) return;
   980|  const bodyData = { chapterId: chapterId.value || 1, progress: (chapterProgress.value || 0) / 100 };
   981|  try {
   982|    await uni.request({
   983|      url: '/api/books/' + book.value.id + '/progress',
   984|      method: 'POST',
   985|      header: {
   986|        'Authorization': 'Bearer ' + token,
   987|        'Content-Type': 'application/json'
   988|      },
   989|      data: bodyData,
   990|    });
   991|  } catch (e) {}
   992|}
   993|
   994|/* ========== 书架 ========== */
   995|async function toggleShelf() {
   996|  if (!book.value.id) return;
   997|  if (inShelf.value) {
   998|    await removeFromShelf(book.value.id);
   999|    inShelf.value = false;
  1000|    uni.showToast({ title: '已移除书架', icon: 'none' });
  1001|  } else {
  1002|    await addToShelf(book.value.id);
  1003|    inShelf.value = true;
  1004|    uni.showToast({ title: '已加入书架', icon: 'none' });
  1005|  }
  1006|}
  1007|
  1008|/* ========== 配置自动保存 ========== */
  1009|function debounceSaveConfig() {
  1010|  if (configSaveTimer) clearTimeout(configSaveTimer);
  1011|  configSaveTimer = setTimeout(() => {
  1012|    saveReaderConfig({
  1013|      fontSize: fontSize.value,
  1014|      lineHeight: Math.round(lineHeight.value * 100),
  1015|      theme: theme.value,
  1016|      brightness: brightness.value,
  1017|    }).catch(() => {});
  1018|  }, 1000);
  1019|}
  1020|
  1021|/* ========== 听书 ========== */
  1022|function togglePlay() {
  1023|  isPlaying.value = !isPlaying.value;
  1024|  if (isPlaying.value) {
  1025|    // 开始播放当前章节内容
  1026|    const currentBlock = blocks.value.find(b => b.id === currentVisibleChapterId.value);
  1027|    if (currentBlock) {
  1028|      startTTS(currentBlock.content);
  1029|    }
  1030|  } else {
  1031|    stopTTS();
  1032|  }
  1033|}
  1034|
  1035|let ttsUtterance: SpeechSynthesisUtterance | null = null;
  1036|function startTTS(text: string) {
  1037|  // #ifdef H5
  1038|  if ('speechSynthesis' in window) {
  1039|    stopTTS();
  1040|    ttsUtterance = new SpeechSynthesisUtterance(text);
  1041|    ttsUtterance.lang = 'zh-CN';
  1042|    ttsUtterance.onend = () => { isPlaying.value = false; };
  1043|    window.speechSynthesis.speak(ttsUtterance);
  1044|  }
  1045|  // #endif
  1046|}
  1047|function stopTTS() {
  1048|  // #ifdef H5
  1049|  if ('speechSynthesis' in window) {
  1050|    window.speechSynthesis.cancel();
  1051|  }
  1052|  // #endif
  1053|}
  1054|
  1055|/* ========== 章节已读 ========== */
  1056|function markCurrentChapterRead() {
  1057|  const cid = currentVisibleChapterId.value;
  1058|  if (cid && !readChapterIds.value.has(cid)) {
  1059|    readChapterIds.value.add(cid);
  1060|    markChapterRead(cid).catch(() => {});
  1061|  }
  1062|}
  1063|</script>
