  1582|
  1583|/* ========== 翻页动画 ========== */
  1584|
  1585|/* slide: 淡入位移 */
  1586|@keyframes slideLeftIn {
  1587|  from { opacity: 0; transform: translateX(60rpx); }
  1588|  to { opacity: 1; transform: translateX(0); }
  1589|}
  1590|@keyframes slideRightIn {
  1591|  from { opacity: 0; transform: translateX(-60rpx); }
  1592|  to { opacity: 1; transform: translateX(0); }
  1593|}
  1594|.anim-slide-left {
  1595|  animation: slideLeftIn 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  1596|}
  1597|.anim-slide-right {
  1598|  animation: slideRightIn 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  1599|}
  1600|
  1601|/* cover: 覆盖翻页 */
  1602|@keyframes coverIn {
  1603|  from { opacity: 0; transform: translateX(100%); }
  1604|  to { opacity: 1; transform: translateX(0); }
  1605|}
  1606|@keyframes coverOut {
  1607|  from { opacity: 0; transform: translateX(-100%); }
  1608|  to { opacity: 1; transform: translateX(0); }
  1609|}
  1610|.anim-cover-in {
  1611|  animation: coverIn 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  1612|}
  1613|.anim-cover-out {
  1614|  animation: coverOut 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  1615|}
  1616|
  1617|/* sim: 仿真翻页（3D 旋转） */
  1618|@keyframes simRight {
  1619|  from { opacity: 0; transform: perspective(1200rpx) rotateY(-25deg) translateX(80rpx); }
  1620|  to { opacity: 1; transform: perspective(1200rpx) rotateY(0) translateX(0); }
  1621|}
  1622|@keyframes simLeft {
  1623|  from { opacity: 0; transform: perspective(1200rpx) rotateY(25deg) translateX(-80rpx); }
  1624|  to { opacity: 1; transform: perspective(1200rpx) rotateY(0) translateX(0); }
  1625|}
  1626|.anim-sim-right {
  1627|  animation: simRight 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  1628|}
  1629|.anim-sim-left {
  1630|  animation: simLeft 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  1631|}
  1632|</style>
  1633|