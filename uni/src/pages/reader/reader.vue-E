   271|<script setup lang="ts">
   272|import { ref, computed, onMounted, nextTick, onUnmounted, watch } from 'vue';
   273|import { onLoad } from '@dcloudio/uni-app';
   274|import { fetchBook, fetchChapters, fetchChapter, checkShelf, addToShelf, removeFromShelf, markChapterRead, saveProgress, type Book, type Chapter } from '@/api/book';
   275|import { fetchReaderConfig, saveReaderConfig } from '@/api/user';
   276|import { adComplete, adUnlock } from '@/api/ad';
   277|
   278|type ThemeKey = 'dark' | 'light' | 'sepia' | 'green';
   279|
   280|const themeList = [
   281|  { key: 'dark' as ThemeKey, label: '夜间', color: '#141210' },
   282|  { key: 'light' as ThemeKey, label: '日间', color: '#F5F5F0' },
   283|  { key: 'sepia' as ThemeKey, label: '羊皮纸', color: '#F4ECD8' },
   284|  { key: 'green' as ThemeKey, label: '护眼', color: '#C7EDCC' },
   285|];
   286|
   287|const themeVars: Record<ThemeKey, Record<string, string>> = {
   288|  dark: {
   289|    '--page-bg': '#141210',
   290|    '--text-primary': '#D4CFC9',
   291|    '--text-title': '#FAF8F5',
   292|    '--panel-bg': 'rgba(30,28,26,0.95)',
