/* pages/store/store.wxss */

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 16px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  color: #868e96;
  border-radius: 8px;
  transition: all 0.2s;
}

.tab-active {
  background: #339af0;
  color: #fff;
  font-weight: bold;
}

/* 书籍网格 */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.book-item {
  width: calc(50% - 6px);
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
}

.book-cover {
  width: 100%;
  height: 180px;
  border-radius: 12px 12px 0 0;
}

.book-info {
  padding: 12px;
}

.book-title {
  font-size: 14px;
  color: #1e1e1e;
  font-weight: bold;
  display: block;
  margin-bottom: 4px;
}

.book-author {
  font-size: 12px;
  color: #868e96;
  display: block;
  margin-bottom: 8px;
}

.book-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.book-score {
  font-size: 12px;
  color: #fab005;
  font-weight: bold;
}

.book-price {
  font-size: 12px;
  color: #339af0;
}
