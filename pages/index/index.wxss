/* pages/index/index.wxss */

/* 搜索栏 */
.search-bar {
  margin-bottom: 16px;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 24px;
  padding: 10px 16px;
}

.search-icon {
  font-size: 14px;
  margin-right: 8px;
  color: #868e96;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #1e1e1e;
}

.search-placeholder {
  color: #adb5bd;
}

/* Banner */
.banner-swiper {
  height: 140px;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 16px;
}

.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  color: #fff;
  font-size: 24px;
  font-weight: bold;
}

/* 分类入口 */
.category-section {
  margin-bottom: 16px;
}

.category-list {
  display: flex;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-bottom: 8px;
}

.category-name {
  font-size: 12px;
  color: #1e1e1e;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding: 0 4px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #1e1e1e;
}

.section-more {
  font-size: 12px;
  color: #868e96;
}

/* 精选推荐横向滚动 */
.featured-scroll {
  margin-bottom: 20px;
}

.featured-list {
  display: flex;
  padding: 4px;
}

.featured-item {
  margin-right: 12px;
  width: 100px;
}

.featured-cover {
  width: 100px;
  height: 140px;
  margin-bottom: 8px;
}

.featured-title {
  font-size: 14px;
  color: #1e1e1e;
  display: block;
}

.featured-author {
  font-size: 12px;
  color: #868e96;
}

/* 视频列表 */
.video-list {
  margin-bottom: 20px;
}

.video-item {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.video-cover {
  width: 120px;
  height: 80px;
  position: relative;
  flex-shrink: 0;
  margin-right: 12px;
}

.video-play {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 14px;
}

.video-duration {
  position: absolute;
  bottom: 6px;
  right: 6px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 14px;
  color: #1e1e1e;
  margin-bottom: 6px;
  display: block;
}

.video-author {
  font-size: 12px;
  color: #868e96;
}
