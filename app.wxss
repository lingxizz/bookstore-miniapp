/* app.wxss - 全局样式 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #1e1e1e;
  font-size: 14px;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 16px;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 主按钮 */
.btn-primary {
  background: #339af0;
  color: #fff;
  border-radius: 24px;
  text-align: center;
  font-size: 16px;
  padding: 12px 0;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 辅助按钮 */
.btn-secondary {
  background: #f8f9fa;
  color: #1e1e1e;
  border-radius: 24px;
  text-align: center;
  font-size: 14px;
  padding: 10px 0;
  border: none;
}

.btn-secondary::after {
  border: none;
}

/* 颜色占位封面 */
.cover-placeholder {
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 12px;
  font-weight: bold;
  text-align: center;
  padding: 8px;
}
